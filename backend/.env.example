# ---- 应用 ----
APP_NAME="Movie Agent Lab"
APP_ENV=dev
API_V1_PREFIX=/api/v1
# 前端跨域来源，逗号分隔
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- 数据库（第一阶段复用旧 MySQL）----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=integratedrecsys

# ---- Redis（复用旧 embedding 缓存）----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ---- 鉴权（JWT）----
JWT_SECRET_KEY=please-change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---- TF Serving（传统推荐排序模型，替代旧硬编码 IP）----
TF_SERVING_NEURALCF_URL=http://127.0.0.1:8503/v1/models/NeuralCF:predict
TF_SERVING_DEEPCROSSING_URL=http://127.0.0.1:8502/v1/models/DeepCrossing:predict
TF_SERVING_WIDEANDDEEP_URL=http://127.0.0.1:8501/v1/models/WideAndDeep:predict
# 是否真实调用 TF Serving，false 时使用本地打分回退，便于无模型环境开发
TF_SERVING_ENABLED=false

# ---- LLM Provider（对话推荐，替代前端硬编码 Spark Key）----
# 可选：mock / openai / volcano / spark
LLM_PROVIDER=mock

# OpenAI 官方 / One API 兼容中转
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 字节跳动火山引擎 Ark（豆包系列）
# 控制台获取 API Key：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
# model 填写 Endpoint ID（ep-xxxx）或 Model ID，参考：https://www.volcengine.com/docs/82379/1330310
VOLCANO_API_KEY=
VOLCANO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCANO_MODEL=doubao-seed-2-0-lite-250428

# 讯飞星火（新版 HTTP REST API，APIPassword 鉴权）
# 控制台 → API Key → 复制 APIPassword 填入 SPARK_API_PASSWORD
# 旧版 WebSocket 字段保留，供兼容工具使用
SPARK_API_APP_ID=
SPARK_API_KEY=
SPARK_API_SECRET=
SPARK_API_PASSWORD=
SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v1
SPARK_MODEL=generalv3.5

# ---- 静态资源 CDN（海报、背景、演员图）----
POSTER_CDN_URL=http://127.0.0.1/posters/
POSTER_BG_CDN_URL=http://127.0.0.1/poster_background/
CAST_POSTER_CDN_URL=http://127.0.0.1/cast_poster/

# ---- 向量库（预留，Phase 8）----
VECTOR_STORE_PROVIDER=memory
